{
  "$schema": "vscode://schemas/color-theme",
  "name": "Naviary Pastel Light",
  "type": "light",
  "semanticHighlighting": true,
  "colors": {
    "focusBorder": "#FF781D88",
    "foreground": "#302A22",
    "disabledForeground": "#928675",
    "errorForeground": "#B93434",
    "descriptionForeground": "#746A5F",

    "textLink.foreground": "#B95512",
    "textLink.activeForeground": "#B95512",
    "textBlockQuote.background": "#F8F0E4",
    "textBlockQuote.border": "#E4D2B7",
    "textCodeBlock.background": "#F8F0E4",
    "textPreformat.foreground": "#7A5108",
    "textSeparator.foreground": "#E8DCCB",

    "button.background": "#FF781D",
    "button.foreground": "#11131A",
    "button.hoverBackground": "#FF8A2A",
    "button.secondaryBackground": "#F3E7D6",
    "button.secondaryForeground": "#302A22",
    "button.secondaryHoverBackground": "#EBDCC8",

    "dropdown.background": "#FFFCF4",
    "dropdown.border": "#E4D6C3",
    "dropdown.foreground": "#302A22",

    "input.background": "#FFFCF4",
    "input.border": "#E4D6C3",
    "input.foreground": "#302A22",
    "input.placeholderForeground": "#746A5F",
    "inputOption.activeBorder": "#FF781D",

    "inputValidation.errorBackground": "#FFF0EC",
    "inputValidation.errorBorder": "#C94141",
    "inputValidation.infoBackground": "#EEF6F4",
    "inputValidation.infoBorder": "#23737A",
    "inputValidation.warningBackground": "#FFF3DC",
    "inputValidation.warningBorder": "#C78300",

    "scrollbar.shadow": "#E4D6C3",
    "scrollbarSlider.background": "#CDBEA966",
    "scrollbarSlider.hoverBackground": "#B7A68FAA",
    "scrollbarSlider.activeBackground": "#FF781D88",

    "badge.background": "#FF781D",
    "badge.foreground": "#11131A",
    "progressBar.background": "#FF781D",

    "list.activeSelectionBackground": "#F0CFB0",
    "list.activeSelectionForeground": "#2A241D",
    "list.inactiveSelectionBackground": "#F7E7D6",
    "list.inactiveSelectionForeground": "#302A22",
    "list.hoverBackground": "#F5ECDD",
    "list.hoverForeground": "#2A241D",
    "list.highlightForeground": "#B95512",
    "list.focusOutline": "#00000000",
    "list.activeSelectionIconForeground": "#2A241D",
    "list.errorForeground": "#B93434",
    "list.warningForeground": "#A66C00",

    "tree.indentGuidesStroke": "#E4D6C3",

    "activityBar.background": "#F5ECDD",
    "activityBar.foreground": "#302A22",
    "activityBar.inactiveForeground": "#746A5F",
    "activityBar.border": "#E4D6C3",
    "activityBarBadge.background": "#FF781D",
    "activityBarBadge.foreground": "#11131A",

    "sideBar.background": "#FAF3E8",
    "sideBar.foreground": "#3E362C",
    "sideBar.border": "#E4D6C3",
    "sideBarTitle.foreground": "#302A22",
    "sideBarSectionHeader.background": "#F5ECDD",
    "sideBarSectionHeader.foreground": "#3E362C",
    "sideBarSectionHeader.border": "#E4D6C3",

    "editorGroup.border": "#E4D6C3",
    "editorGroupHeader.tabsBackground": "#FAF3E8",
    "editorGroupHeader.tabsBorder": "#E4D6C3",

    "tab.activeBackground": "#FFFCF4",
    "tab.activeForeground": "#2A241D",
    "tab.border": "#E4D6C3",
    "tab.activeBorderTop": "#FF781D",
    "tab.inactiveBackground": "#F5ECDD",
    "tab.inactiveForeground": "#746A5F",
    "tab.hoverBackground": "#F2E3D2",
    "tab.hoverForeground": "#302A22",
    "tab.unfocusedActiveBorderTop": "#B7A68F",

    "editor.background": "#FFFCF4",
    "editor.foreground": "#302A22",
    "editorLineNumber.foreground": "#746A5F",
    "editorLineNumber.activeForeground": "#665D51",
    "editorCursor.foreground": "#FF781D",
    "editorCursor.background": "#FFFCF4",

    "editor.selectionBackground": "#F1CBA7",
    "editor.selectionHighlightBackground": "#FF781D24",
    "editor.inactiveSelectionBackground": "#D6C7B24D",
    "editor.wordHighlightBackground": "#E7D8C555",
    "editor.wordHighlightStrongBackground": "#FF781D24",
    "editor.findMatchBackground": "#FF781D55",
    "editor.findMatchHighlightBackground": "#C7830038",
    "editor.findRangeHighlightBackground": "#F3E7D688",
    "editor.hoverHighlightBackground": "#F0CFB066",
    "editor.lineHighlightBackground": "#FAF3E8",
    "editor.lineHighlightBorder": "#00000000",

    "editorIndentGuide.background1": "#E8DCCB",
    "editorIndentGuide.activeBackground1": "#B7A68F",
    "editorWhitespace.foreground": "#E4D6C3",

    "editorBracketMatch.background": "#FF781D20",
    "editorBracketMatch.border": "#B95512",

    "editorOverviewRuler.border": "#00000000",
    "editorOverviewRuler.findMatchForeground": "#FF781D99",
    "editorOverviewRuler.warningForeground": "#C78300CC",
    "editorOverviewRuler.errorForeground": "#C94141CC",
    "editorOverviewRuler.infoForeground": "#23737A99",

    "editorError.foreground": "#C94141",
    "editorWarning.foreground": "#C78300",
    "editorInfo.foreground": "#23737A",
    "editorHint.foreground": "#2F7658",

    "editorGutter.background": "#FFFCF4",
    "editorGutter.addedBackground": "#2F7658",
    "editorGutter.modifiedBackground": "#FF781D",
    "editorGutter.deletedBackground": "#C94141",

    "diffEditor.insertedTextBackground": "#2F765822",
    "diffEditor.removedTextBackground": "#C9414124",
    "diffEditor.insertedLineBackground": "#2F765816",
    "diffEditor.removedLineBackground": "#C9414116",

    "panel.background": "#FFFCF4",
    "panel.border": "#E4D6C3",
    "panelTitle.activeForeground": "#2A241D",
    "panelTitle.activeBorder": "#FF781D",
    "panelTitle.inactiveForeground": "#746A5F",

    "statusBar.background": "#F5ECDD",
    "statusBar.foreground": "#302A22",
    "statusBar.border": "#E4D6C3",
    "statusBar.debuggingBackground": "#A94F14",
    "statusBar.debuggingForeground": "#FFFDF7",
    "statusBar.noFolderBackground": "#F5ECDD",
    "statusBarItem.hoverBackground": "#EBDCC8",
    "statusBarItem.prominentBackground": "#F3E7D6",
    "statusBarItem.remoteBackground": "#FF781D",
    "statusBarItem.remoteForeground": "#11131A",

    "titleBar.activeBackground": "#FAF3E8",
    "titleBar.activeForeground": "#302A22",
    "titleBar.border": "#E4D6C3",
    "titleBar.inactiveBackground": "#FAF3E8CC",
    "titleBar.inactiveForeground": "#746A5F",

    "menu.background": "#FFFCF4",
    "menu.foreground": "#302A22",
    "menu.selectionBackground": "#F0CFB0",
    "menu.selectionForeground": "#2A241D",
    "menu.separatorBackground": "#E4D6C3",

    "commandCenter.border": "#E4D6C3",

    "peekView.border": "#E4D2B7",
    "peekViewEditor.background": "#FFFCF4",
    "peekViewEditor.matchHighlightBackground": "#FF781D30",
    "peekViewResult.background": "#FAF3E8",
    "peekViewResult.selectionBackground": "#F0CFB0",
    "peekViewTitle.background": "#FAF3E8",
    "peekViewTitleLabel.foreground": "#2A241D",

    "terminal.background": "#FFFCF4",
    "terminal.foreground": "#302A22",
    "terminalCursor.foreground": "#FF781D",
    "terminal.ansiBlack": "#302A22",
    "terminal.ansiRed": "#B93434",
    "terminal.ansiGreen": "#2F7658",
    "terminal.ansiYellow": "#806600",
    "terminal.ansiBlue": "#2F669E",
    "terminal.ansiMagenta": "#82549B",
    "terminal.ansiCyan": "#23737A",
    "terminal.ansiWhite": "#746A5F",
    "terminal.ansiBrightBlack": "#746A5F",
    "terminal.ansiBrightRed": "#C83737",
    "terminal.ansiBrightGreen": "#2F7658",
    "terminal.ansiBrightYellow": "#9A6400",
    "terminal.ansiBrightBlue": "#2F6FD4",
    "terminal.ansiBrightMagenta": "#7D4FA3",
    "terminal.ansiBrightCyan": "#23737A",
    "terminal.ansiBrightWhite": "#302A22",

    "gitDecoration.addedResourceForeground": "#2F7658",
    "gitDecoration.modifiedResourceForeground": "#B95512",
    "gitDecoration.deletedResourceForeground": "#B93434",
    "gitDecoration.untrackedResourceForeground": "#4B9B79",
    "gitDecoration.ignoredResourceForeground": "#746A5F",

    "notifications.background": "#FFFCF4",
    "notifications.border": "#E4D6C3",
    "notifications.foreground": "#302A22"
  },
  "tokenColors": [
    {
      "name": "Comments",
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#7B7062",
        "fontStyle": "italic"
      }
    },
    {
      "name": "HTML JSX Text Content",
      "scope": [
        "meta.jsx.children",
        "meta.jsx.children.tsx",
        "meta.jsx.children.js",
        "text.html.basic",
        "text.html.derivative",
        "text.html.markdown"
      ],
      "settings": {
        "foreground": "#302A22"
      }
    },
    {
      "name": "Strings",
      "scope": [
        "string",
        "markup.inline.raw",
        "string.template"
      ],
      "settings": {
        "foreground": "#2F7658"
      }
    },
    {
      "name": "Numbers and constants",
      "scope": [
        "constant.numeric",
        "constant.language",
        "constant.character.escape"
      ],
      "settings": {
        "foreground": "#82549B"
      }
    },
    {
      "name": "Keywords and storage",
      "scope": [
        "keyword",
        "storage",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#B95512"
      }
    },
    {
      "name": "This keyword",
      "scope": [
        "variable.language.this",
        "variable.language.this.ts",
        "variable.language.this.js"
      ],
      "settings": {
        "foreground": "#A9480E"
      }
    },
    {
      "name": "New keyword",
      "scope": [
        "keyword.operator.new",
        "keyword.operator.new.js",
        "keyword.operator.new.ts",
        "keyword.operator.expression.new",
        "keyword.operator.expression.new.js",
        "keyword.operator.expression.new.ts",
        "keyword.control.new"
      ],
      "settings": {
        "foreground": "#A9480E"
      }
    },
    {
      "name": "Typeof operator",
      "scope": [
        "keyword.operator.typeof",
        "keyword.operator.typeof.js",
        "keyword.operator.typeof.jsx",
        "keyword.operator.typeof.ts",
        "keyword.operator.typeof.tsx",
        "keyword.operator.expression.typeof",
        "keyword.operator.expression.typeof.js",
        "keyword.operator.expression.typeof.jsx",
        "keyword.operator.expression.typeof.ts",
        "keyword.operator.expression.typeof.tsx"
      ],
      "settings": {
        "foreground": "#82549B"
      }
    },
    {
      "name": "Functions",
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call",
        "variable.function",
        "meta.member.access entity.name.function",
        "meta.member.access variable.function",
        "meta.property.access entity.name.function",
        "meta.property.object entity.name.function"
      ],
      "settings": {
        "foreground": "#23737A"
      }
    },
    {
      "name": "Variables and identifiers",
      "scope": [
        "variable",
        "variable.other",
        "variable.other.readwrite",
        "meta.definition.variable.name",
        "support.variable"
      ],
      "settings": {
        "foreground": "#302A22"
      }
    },
    {
      "name": "Object properties",
      "scope": [
        "variable.other.property",
        "meta.object-literal.key",
        "support.variable.property"
      ],
      "settings": {
        "foreground": "#23737A"
      }
    },
    {
      "name": "Parameters",
      "scope": [
        "variable.parameter",
        "meta.parameters"
      ],
      "settings": {
        "foreground": "#665D51"
      }
    },
    {
      "name": "Types and classes",
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.name.interface",
        "entity.other.inherited-class",
        "support.type",
        "support.class"
      ],
      "settings": {
        "foreground": "#2F669E"
      }
    },
    {
      "name": "Decorators",
      "scope": [
        "meta.decorator",
        "entity.name.function.decorator",
        "punctuation.decorator"
      ],
      "settings": {
        "foreground": "#82549B"
      }
    },
    {
      "name": "Tags and components",
      "scope": [
        "entity.name.tag",
        "meta.tag",
        "support.class.component"
      ],
      "settings": {
        "foreground": "#B95512"
      }
    },
    {
      "name": "Tag punctuation",
      "scope": [
        "punctuation.definition.tag",
        "punctuation.definition.tag.begin",
        "punctuation.definition.tag.end"
      ],
      "settings": {
        "foreground": "#B95512"
      }
    },
    {
      "name": "Attributes",
      "scope": [
        "attribute.name",
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#23737A"
      }
    },
    {
      "name": "Punctuation",
      "scope": [
        "punctuation",
        "meta.brace",
        "meta.delimiter"
      ],
      "settings": {
        "foreground": "#665D51"
      }
    },
    {
      "name": "Invalid",
      "scope": [
        "invalid",
        "invalid.illegal"
      ],
      "settings": {
        "foreground": "#C94141",
        "fontStyle": "bold"
      }
    }
  ],
  "semanticTokenColors": {
    "namespace": "#23737A",

    "class": "#2F669E",
    "struct": "#2F669E",
    "type": "#2F669E",
    "interface": "#2F669E",
    "enum": "#2F669E",
    "typeParameter": "#23737A",

    "parameter": "#665D51",
    "variable": "#302A22",
    "variable.readonly": "#3E362C",
    "property": "#23737A",
    "property.readonly": "#23737A",

    "function": "#23737A",
    "method": "#23737A",
    "macro": "#82549B",

    "keyword": "#B95512",
    "operator": "#665D51",

    "comment": {
      "foreground": "#7B7062",
      "italic": true
    },

    "string": "#2F7658",
    "number": "#82549B",
    "regexp": "#2F7658",

    "decorator": "#82549B"
  }
}
