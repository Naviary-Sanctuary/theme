    "button.secondaryForeground": "#E1E7F0",
    "button.secondaryHoverBackground": "#344057",

    "dropdown.background": "#293245",
    "dropdown.border": "#3A465C",
    "dropdown.foreground": "#E1E7F0",

    "input.background": "#293245",
    "input.border": "#3A465C",
    "input.foreground": "#E1E7F0",
    "input.placeholderForeground": "#A5B2C5",
    "inputOption.activeBorder": "#FF781D88",

    "inputValidation.errorBackground": "#48242E",
