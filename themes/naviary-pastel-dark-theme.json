    "list.activeSelectionBackground": "#40556A",
    "list.activeSelectionForeground": "#F8FAFC",
    "list.inactiveSelectionBackground": "#343E4D",
    "list.inactiveSelectionForeground": "#D8DEE9",
    "list.hoverBackground": "#384454",
    "list.hoverForeground": "#F8FAFC",
    "list.highlightForeground": "#FF781D",
    "list.focusBackground": "#40556A",
    "list.focusForeground": "#F8FAFC",
    "list.focusOutline": "#00000000",
    "list.activeSelectionIconForeground": "#FF9A4A",
    "list.errorForeground": "#FF6B6B",
    "list.warningForeground": "#EBCB8B",

    "tree.indentGuidesStroke": "#465267",

    "activityBar.background": "#2B323E",
    "activityBar.foreground": "#E5E9F0",
    "activityBar.inactiveForeground": "#A0ABBC",
    "activityBar.border": "#364052",
    "activityBarBadge.background": "#FF781D",
    "activityBarBadge.foreground": "#11131A",

    "sideBar.background": "#2B323E",
    "sideBar.foreground": "#C7D0DC",
    "sideBar.border": "#364052",
    "sideBarTitle.foreground": "#F5F7FA",
    "sideBarSectionHeader.background": "#333B48",
    "sideBarSectionHeader.foreground": "#D8DEE9",
    "sideBarSectionHeader.border": "#465267",

    "editorGroup.border": "#364052",
    "editorGroupHeader.tabsBackground": "#2B323E",
    "editorGroupHeader.tabsBorder": "#364052",

    "tab.activeBackground": "#333B48",
    "tab.activeForeground": "#F5F7FA",
    "tab.border": "#364052",
    "tab.activeBorderTop": "#FF781D",
    "tab.inactiveBackground": "#2B323E",
    "tab.inactiveForeground": "#A0ABBC",
    "tab.hoverBackground": "#384454",
    "tab.hoverForeground": "#E5E9F0",
    "tab.unfocusedActiveBorderTop": "#465267",

    "editor.background": "#2E3440",
    "editor.foreground": "#D8DEE9",
    "editorLineNumber.foreground": "#94A0B2",
    "editorLineNumber.activeForeground": "#C7D0DC",
    "editorCursor.foreground": "#FF9A4A",
    "editorCursor.background": "#2E3440",

    "editor.selectionBackground": "#40556A",
    "editor.selectionHighlightBackground": "#4B5D7260",
    "editor.inactiveSelectionBackground": "#37455766",
    "editor.wordHighlightBackground": "#46526755",
    "editor.wordHighlightStrongBackground": "#FF781D20",
    "editor.findMatchBackground": "#FF781D55",
    "editor.findMatchHighlightBackground": "#88C0D033",
    "editor.findRangeHighlightBackground": "#36405288",
    "editor.hoverHighlightBackground": "#37455766",
    "editor.lineHighlightBackground": "#333B48",
    "editor.lineHighlightBorder": "#00000000",

    "editorIndentGuide.background1": "#364052",
    "editorIndentGuide.activeBackground1": "#556276",
    "editorWhitespace.foreground": "#465267",

    "editorBracketMatch.background": "#46526744",
    "editorBracketMatch.border": "#88C0D0",
    "editorBracketHighlight.foreground1": "#D8DEE9",
    "editorBracketHighlight.foreground2": "#98C8D6",
    "editorBracketHighlight.foreground3": "#B7A6E0",
    "editorBracketHighlight.foreground4": "#D7B978",
    "editorBracketHighlight.foreground5": "#A3BE8C",
    "editorBracketHighlight.foreground6": "#E08A70",
    "editorBracketHighlight.unexpectedBracket.foreground": "#FF6B6B",

    "editorOverviewRuler.border": "#00000000",
    "editorOverviewRuler.findMatchForeground": "#FF781D99",
    "editorOverviewRuler.warningForeground": "#EBCB8BCC",
    "editorOverviewRuler.errorForeground": "#FF4D4DCC",
    "editorOverviewRuler.infoForeground": "#88C0D099",

    "editorError.foreground": "#FF6B6B",
    "editorWarning.foreground": "#EBCB8B",
    "editorInfo.foreground": "#88C0D0",
    "editorHint.foreground": "#A3BE8C",

    "editorGutter.background": "#2E3440",
    "editorGutter.addedBackground": "#B3C996",
    "editorGutter.modifiedBackground": "#E6A03D",
    "editorGutter.deletedBackground": "#FF6B6B",

    "editorWidget.background": "#353D4C",
    "editorWidget.foreground": "#E5E9F0",
    "editorWidget.border": "#465267",
    "editorHoverWidget.background": "#353D4C",
    "editorHoverWidget.foreground": "#E5E9F0",
    "editorHoverWidget.border": "#465267",
    "editorActionList.background": "#353D4C",
    "editorActionList.foreground": "#E5E9F0",
    "editorActionList.focusForeground": "#F8FAFC",
    "quickInput.background": "#353D4C",
    "quickInput.foreground": "#E5E9F0",
    "quickInputTitle.background": "#333B48",
    "quickInputList.focusBackground": "#40556A",
    "quickInputList.focusForeground": "#F8FAFC",
    "quickInputList.focusIconForeground": "#FF9A4A",

    "diffEditor.insertedTextBackground": "#A3BE8C22",
    "diffEditor.removedTextBackground": "#FF4D4D2E",
    "diffEditor.insertedLineBackground": "#A3BE8C18",
    "diffEditor.removedLineBackground": "#FF4D4D18",

    "panel.background": "#2B323E",
    "panel.border": "#364052",
    "panelTitle.activeForeground": "#F5F7FA",
    "panelTitle.activeBorder": "#FF781D",
    "panelTitle.inactiveForeground": "#A0ABBC",

    "statusBar.background": "#2B323E",
    "statusBar.foreground": "#D8DEE9",
    "statusBar.border": "#364052",
    "statusBar.debuggingBackground": "#7A3A12",
    "statusBar.debuggingForeground": "#FFF8F3",
    "statusBar.noFolderBackground": "#2B323E",
    "statusBarItem.hoverBackground": "#384454",
    "statusBarItem.prominentBackground": "#353D4C",
    "statusBarItem.remoteBackground": "#FF781D",
    "statusBarItem.remoteForeground": "#11131A",

    "titleBar.activeBackground": "#2B323E",
    "titleBar.activeForeground": "#D8DEE9",
    "titleBar.border": "#364052",
    "titleBar.inactiveBackground": "#2B323ECC",
    "titleBar.inactiveForeground": "#A0ABBC",

    "menu.background": "#353D4C",
    "menu.foreground": "#E5E9F0",
    "menu.selectionBackground": "#384454",
    "menu.selectionForeground": "#F5F7FA",
    "menu.separatorBackground": "#465267",

    "commandCenter.border": "#465267",

    "peekView.border": "#465267",
    "peekViewEditor.background": "#2E3440",
    "peekViewEditor.matchHighlightBackground": "#FF781D33",
    "peekViewResult.background": "#333A48",
    "peekViewResult.selectionBackground": "#40556A",
    "peekViewTitle.background": "#2E3440",
    "peekViewTitleLabel.foreground": "#F5F7FA",

    "terminal.background": "#2E3440",
    "terminal.foreground": "#D8DEE9",
    "terminalCursor.foreground": "#FF9A4A",
    "terminal.ansiBlack": "#94A0B2",
    "terminal.ansiRed": "#FF6B6B",
    "terminal.ansiGreen": "#A3BE8C",
    "terminal.ansiYellow": "#EBCB8B",
    "terminal.ansiBlue": "#8FB9D8",
    "terminal.ansiMagenta": "#C9A4C1",
    "terminal.ansiCyan": "#98C8D6",
    "terminal.ansiWhite": "#E5E9F0",
    "terminal.ansiBrightBlack": "#A0ABBC",
    "terminal.ansiBrightRed": "#FF7A7A",
    "terminal.ansiBrightGreen": "#B3C996",
    "terminal.ansiBrightYellow": "#FFD76A",
    "terminal.ansiBrightBlue": "#A5B4E8",
    "terminal.ansiBrightMagenta": "#D0B0D6",
    "terminal.ansiBrightCyan": "#8FBCBB",
    "terminal.ansiBrightWhite": "#F8FAFC",

    "gitDecoration.addedResourceForeground": "#B3C996",
    "gitDecoration.modifiedResourceForeground": "#EBCB8B",
    "gitDecoration.deletedResourceForeground": "#FF6B6B",
    "gitDecoration.untrackedResourceForeground": "#B4CC9A",
    "gitDecoration.ignoredResourceForeground": "#94A0B2",

    "notifications.background": "#353D4C",
    "notifications.border": "#465267",
    "notifications.foreground": "#E5E9F0"
  },
  "tokenColors": [
    {
      "name": "Comments",
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#96A3B4",
        "fontStyle": "italic"
      }
    },
    {
      "name": "HTML JSX Text Content",
      "scope": [
        "meta.jsx.children",
        "meta.jsx.children.tsx",
        "meta.jsx.children.js",
        "text.html.basic",
        "text.html.derivative",
        "text.html.markdown"
      ],
      "settings": {
        "foreground": "#D8DEE9"
      }
    },
    {
      "name": "Strings",
      "scope": [
        "string",
        "markup.inline.raw",
        "string.template"
      ],
      "settings": {
        "foreground": "#B3C996"
      }
    },
    {
      "name": "Numbers and constants",
      "scope": [
        "constant.numeric",
        "constant.language",
        "constant.character.escape"
      ],
      "settings": {
        "foreground": "#C9A4C1"
      }
    },
    {
      "name": "Keywords and storage",
      "scope": [
        "keyword",
        "storage",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#E08A70"
      }
    },
    {
      "name": "This keyword",
      "scope": [
        "variable.language.this",
        "variable.language.this.ts",
        "variable.language.this.js"
      ],
      "settings": {
        "foreground": "#E08A70"
      }
    },
    {
      "name": "New keyword",
      "scope": [
        "keyword.operator.new",
        "keyword.operator.new.js",
        "keyword.operator.new.ts",
        "keyword.operator.expression.new",
        "keyword.operator.expression.new.js",
        "keyword.operator.expression.new.ts",
        "keyword.control.new"
      ],
      "settings": {
        "foreground": "#FF781D"
      }
    },
    {
      "name": "Typeof operator",
      "scope": [
        "keyword.operator.typeof",
        "keyword.operator.typeof.js",
        "keyword.operator.typeof.jsx",
        "keyword.operator.typeof.ts",
        "keyword.operator.typeof.tsx",
        "keyword.operator.expression.typeof",
        "keyword.operator.expression.typeof.js",
        "keyword.operator.expression.typeof.jsx",
        "keyword.operator.expression.typeof.ts",
        "keyword.operator.expression.typeof.tsx"
      ],
      "settings": {
        "foreground": "#C9A4C1"
      }
    },
    {
      "name": "Operators",
      "scope": [
        "keyword.operator",
        "storage.type.function.arrow"
      ],
      "settings": {
        "foreground": "#AAB5C4"
      }
    },
    {
      "name": "Functions",
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call",
        "variable.function"
      ],
      "settings": {
        "foreground": "#98C8D6"
      }
    },
    {
      "name": "Variables and identifiers",
      "scope": [
        "variable",
        "variable.other",
        "variable.other.readwrite",
        "meta.definition.variable.name",
        "support.variable"
      ],
      "settings": {
        "foreground": "#D8DEE9"
      }
    },
    {
      "name": "Object properties",
      "scope": [
        "variable.other.property",
        "meta.object-literal.key",
        "support.variable.property"
      ],
      "settings": {
        "foreground": "#D8DEE9"
      }
    },
    {
      "name": "Methods and member calls",
      "scope": [
        "entity.name.function.method",
        "meta.method-call",
        "meta.method-call entity.name.function",
        "meta.method-call variable.function",
        "meta.member.access entity.name.function",
        "meta.member.access variable.function",
        "meta.property.access entity.name.function",
        "meta.property.object entity.name.function",
        "support.function.method"
      ],
      "settings": {
        "foreground": "#98C8D6"
      }
    },
    {
      "name": "Parameters",
      "scope": [
        "variable.parameter",
        "meta.parameters"
      ],
      "settings": {
        "foreground": "#E5E9F0"
      }
    },
    {
      "name": "Types and classes",
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.name.interface",
        "entity.other.inherited-class",
        "support.type",
        "support.class"
      ],
      "settings": {
        "foreground": "#B7A6E0"
      }
    },
    {
      "name": "Decorators",
      "scope": [
        "meta.decorator",
        "entity.name.function.decorator",
        "punctuation.decorator",
        "meta.decorator entity.name.function",
        "meta.decorator support.function",
        "meta.decorator support.type",
        "meta.decorator variable.other"
      ],
      "settings": {
        "foreground": "#D0B0D6"
      }
    },
    {
      "name": "Tags and components",
      "scope": [
        "entity.name.tag",
        "meta.tag",
        "support.class.component"
      ],
      "settings": {
        "foreground": "#FF781D"
      }
    },
    {
      "name": "Tag punctuation",
      "scope": [
        "punctuation.definition.tag",
        "punctuation.definition.tag.begin",
        "punctuation.definition.tag.end"
      ],
      "settings": {
        "foreground": "#FF781D"
      }
    },
    {
      "name": "Attributes",
      "scope": [
        "attribute.name",
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#8FBCBB"
      }
    },
    {
      "name": "Punctuation",
      "scope": [
        "punctuation",
        "meta.brace",
        "meta.delimiter"
      ],
      "settings": {
        "foreground": "#AAB5C4"
      }
    },
    {
      "name": "Invalid",
      "scope": [
        "invalid",
        "invalid.illegal"
      ],
      "settings": {
        "foreground": "#FF6B6B",
        "fontStyle": "bold"
      }
    }
  ],
  "semanticTokenColors": {
    "namespace": "#98C8D6",

    "class": "#B7A6E0",
    "struct": "#B7A6E0",
    "type": "#B7A6E0",
    "interface": "#B7A6E0",
    "enum": "#B7A6E0",
    "typeParameter": "#B7A6E0",

    "parameter": "#E5E9F0",
    "variable": "#D8DEE9",
    "variable.readonly": "#E5E9F0",
    "property": "#D8DEE9",
    "property.readonly": "#E5E9F0",
    "property.declaration": "#D8DEE9",
    "property.declaration.readonly": "#E5E9F0",
    "property.readonly.declaration": "#E5E9F0",

    "function": "#98C8D6",
    "method": "#98C8D6",
    "macro": "#D0B0D6",
    "function.decorator": "#D0B0D6",
    "method.decorator": "#D0B0D6",
    "class.decorator": "#D0B0D6",
    "property.decorator": "#D0B0D6",
    "variable.decorator": "#D0B0D6",

    "keyword": "#E08A70",
    "operator": "#AAB5C4",

    "comment": {
      "foreground": "#96A3B4",
      "italic": true
    },

    "string": "#B3C996",
    "number": "#C9A4C1",
    "regexp": "#B3C996",

    "decorator": "#D0B0D6"
  }
}
